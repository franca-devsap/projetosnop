<IconTabFilter text="{i18n>salesPlanForecast}" key="previsao">
              <customData>
                <BadgeCustomData value="{app>/forecastBadgeCount}" visible="{app>/forecastBadgeVisible}"/>
              </customData>
              <OverflowToolbar>
                <ObjectStatus text="{app>/forecastStatus}" state="Information"/>
                <ToolbarSpacer/>
                <Button text="{i18n>saveForecast}" icon="sap-icon://save" type="Accept" press=".onSaveForecast"/>
                <Button text="{i18n>deleteForecastItems}" icon="sap-icon://delete" type="Reject" press=".onRemoveForecastSelection"/>
                <Button text="{i18n>addManualItem}" icon="sap-icon://add-document" type="Emphasized" press=".onAddManualForecast"/>
              </OverflowToolbar>
              <smartTable:SmartTable id="forecastSmartTable" tableType="ResponsiveTable" enableAutoBinding="false" useVariantManagement="false" useTablePersonalisation="true" showRowCount="true" width="100%">
                <Table
                  id="forecastTable"
                  mode="MultiSelect"
                  sticky="ColumnHeaders"
                  fixedLayout="false"
                  width="100%"
                  items="{app>/forecastRows}"
                  class="forecastEditTable zebraTable">
                  <columns>
                    <Column width="7rem"><Text text="{i18n>type}"/></Column>
                    <Column width="8rem"><Text text="{i18n>number}"/></Column>
                    <Column width="12rem"><Text text="{i18n>client}"/></Column>
                    <Column width="12rem"><Text text="{i18n>product}"/></Column>
                    <Column width="7rem"><Text text="{i18n>mtsMto}"/></Column>
                    <Column width="9rem"><Text text="{i18n>situation}"/></Column>
                    <Column width="10rem"><Text text="{i18n>technicalStatus}"/></Column>
                    <Column hAlign="End" width="7rem"><Text text="{i18n>qty}"/></Column>
                    <Column hAlign="End" width="8rem"><Text text="{i18n>unitValue}"/></Column>
                    <Column hAlign="End" width="8rem"><Text text="{i18n>totalValue}"/></Column>
                    <Column hAlign="End" width="7rem"><Text text="{i18n>freight}"/></Column>
                    <Column hAlign="End" width="6rem"><Text text="{i18n>probability}"/></Column>
                    <Column hAlign="End" width="8rem"><Text text="{i18n>weightedValue}"/></Column>
                    <Column width="9rem"><Text text="{i18n>date}"/></Column>
                    <Column width="6rem"><Text text="{i18n>month}"/></Column>
                    <Column width="8rem"><Text text="{i18n>status}"/></Column>
                  </columns>
                  <items>
                    <ColumnListItem highlight="{app>highlight}">
                      <cells>
                        <ObjectStatus text="{app>tipo}" state="{app>tipoState}"/>
                        <Text text="{app>numero}"/>
                        <Input value="{app>cliente}" editable="{app>editable}" width="11rem" showSuggestion="true" suggestionItems="{app>/valueHelps/clients}">
                          <suggestionItems>
                            <core:Item key="{app>key}" text="{app>text}"/>
                          </suggestionItems>
                        </Input>
                        <Input value="{app>produto}" editable="{app>editable}" width="11rem" showSuggestion="true" suggestionItems="{app>/valueHelps/products}">
                          <suggestionItems>
                            <core:Item key="{app>key}" text="{app>text}"/>
                          </suggestionItems>
                        </Input>
                        <HBox alignItems="Center" justifyContent="Center" width="100%" visible="{= !${app>isBudgetForecast} }">
                          <ObjectStatus text="{app>mtsMto}" state="Error" inverted="true" visible="{= ${app>mtsMto} === 'MTO' }"/>
                          <ObjectStatus text="{app>mtsMto}" state="Information" inverted="true" visible="{= ${app>mtsMto} === 'MTS' }"/>
                        </HBox>
                        <ObjectStatus text="{app>situacao}" state="{app>situacaoState}" visible="{= !${app>isBudgetForecast} }"/>
                        <ObjectStatus text="{app>technicalStatusText}" state="{app>technicalStatusState}" icon="{app>technicalStatusIcon}" visible="{= !${app>isBudgetForecast} }"/>
                        <Input value="{app>qtd}" type="Number" textAlign="End" width="6rem" editable="{app>qtdEditable}" liveChange=".onForecastFieldChange"/>
                        <HBox alignItems="Center" justifyContent="End" width="100%">
                          <Input value="{app>valorUnit}" type="Number" textAlign="End" width="7rem" editable="{app>valorUnitEditable}" liveChange=".onForecastFieldChange" visible="{app>valorUnitEditable}"/>
                          <ObjectNumber number="{app>valorUnitDisplay}" unit="R$" visible="{= !${app>valorUnitEditable} }"/>
                        </HBox>
                        <ObjectNumber number="{app>valorTotalDisplay}" unit="R$"/>
                        <ObjectNumber number="{app>freteDisplay}" unit="R$"/>
                        <Input value="{app>prob}" type="Number" textAlign="End" width="5rem" editable="{app>editable}" liveChange=".onForecastFieldChange"/>
                        <ObjectNumber number="{app>valorPondDisplay}" unit="R$"/>
                        <DatePicker value="{app>data}" valueFormat="yyyy-MM-dd" displayFormat="dd/MM/yyyy" editable="{app>dataEditable}" change=".onForecastFieldChange"/>
                        <Text text="{app>mes}"/>
                        <ObjectStatus text="{app>status}" state="{app>statusState}"/>
                      </cells>
                    </ColumnListItem>
                  </items>
                </Table>
              </smartTable:SmartTable>
            </IconTabFilter>

